<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>PCL.N.Plugin.Sdk</AssemblyName>
    <RootNamespace>PCL.N.Plugin.Sdk</RootNamespace>
    <LangVersion>14.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <IsPackable>true</IsPackable>
    <IsAotCompatible>true</IsAotCompatible>
    <IsTrimmable>true</IsTrimmable>
    <PackageId>PCL.N.Plugin.Sdk</PackageId>
    <Title>PCL N Plugin SDK</Title>
    <Description>Manifest validation, versioning, and developer helpers for building third-party PCL N plugins.</Description>
    <PackageTags>$(PackageTags);manifest;validation</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../PCL.N.Plugin.Abstractions/PCL.N.Plugin.Abstractions.csproj" />
  </ItemGroup>
</Project>
